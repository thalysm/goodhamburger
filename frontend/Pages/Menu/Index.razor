@page "/menu"
@layout EmptyLayout

<MudContainer MaxWidth="MaxWidth.Large" Class="my-12 px-8">
    <div class="d-flex flex-column flex-sm-row justify-space-between align-center mb-12 gap-4">
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.RestaurantMenu" Color="Color.Primary" Size="Size.Large" Class="mr-4" />
            <MudText Typo="Typo.h2" Class="font-weight-black">CARDÁPIO</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/orders/new" StartIcon="@Icons.Material.Filled.ShoppingBag" Class="px-8">FAZER PEDIDO</MudButton>
    </div>

    @foreach (var type in new[] { "Sandwich", "Side", "Drink" })
    {
        var items = _menuItems.Where(i => i.Type == type).ToList();
        if (items.Any())
        {
            <div class="mb-12" style="max-width: 100%; overflow: hidden">
                <div class="d-flex align-center mb-6">
                    <MudText Typo="Typo.h4" Class="font-weight-bold mr-4" Style="white-space: nowrap">@TranslateType(type).ToUpper()S</MudText>
                    <MudDivider Style="flex-grow: 1" />
                    <MudText Typo="Typo.caption" Class="ml-4" Style="white-space: nowrap; flex-shrink: 0">0@(Array.IndexOf(new[] { "Sandwich", "Side", "Drink" }, type) + 1) / CATEGORIA</MudText>
                </div>

                <MudGrid Spacing="4">
                    @foreach (var item in items)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudPaper Elevation="0" Class="pa-0 rounded-lg overflow-hidden d-flex flex-column" Style="border: 1px solid #eee; height: 100%; background-color: white">
                                <div style="background-color: #f9f9f9; height: 260px; width: 100%; display: flex; align-items: center; justify-content: center" class="pa-4">
                                    <MudImage Src="@GetImageUrl(item.ImageUrl)" Style="max-height: 100%; max-width: 100%" ObjectFit="ObjectFit.Contain" />
                                </div>
                                <div class="pa-6 flex-grow-1">
                                    <div class="d-flex justify-space-between align-start mb-2 gap-2">
                                        <MudText Typo="Typo.h5" Class="font-weight-bold" Style="line-height: 1.2">@item.Name</MudText>
                                        <MudText Color="Color.Primary" Typo="Typo.h6" Style="font-weight: 800; white-space: nowrap">R$ @item.Price.ToString("N2")</MudText>
                                    </div>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
                                        Ingredientes selecionados para uma experiência gourmet inesquecível.
                                    </MudText>
                                    <div class="d-flex gap-2">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Class="px-0">#ARTESANAL</MudChip>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Class="px-0">#FRESCO</MudChip>
                                    </div>
                                </div>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </div>
        }
    }

    <MudPaper Class="pa-8 pa-md-12 mt-16 rounded-xl" Elevation="0" Style="background-color: #1a1a1a; color: white">
        <div class="d-flex align-center justify-space-between mb-10">
            <MudText Typo="Typo.h3" Class="font-weight-black" Color="Color.Primary">OFERTAS DE COMBO</MudText>
            <MudIcon Icon="@Icons.Material.Filled.Percent" Size="Size.Large" Color="Color.Primary" />
        </div>

        <MudGrid Spacing="6">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-6 rounded-lg" Outlined="true" Style="border-color: #333; background: #222; color: white; height: 100%">
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Class="mb-4 font-weight-bold">20% OFF</MudChip>
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-1">CIRCUITO COMPLETO</MudText>
                    <MudText Typo="Typo.caption" Class="mb-4 d-block" Style="color: #888">SANDUÍCHE + ACOMPANHAMENTO + BEBIDA</MudText>
                    <MudText Typo="Typo.body2" Style="color: #bbb">A nossa melhor oferta para matar sua fome com o conjunto completo.</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-6 rounded-lg" Outlined="true" Style="border-color: #333; background: #222; color: white; height: 100%">
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Class="mb-4 font-weight-bold">15% OFF</MudChip>
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-1">COMBO CLÁSSICO</MudText>
                    <MudText Typo="Typo.caption" Class="mb-4 d-block" Style="color: #888">SANDUÍCHE + BEBIDA</MudText>
                    <MudText Typo="Typo.body2" Style="color: #bbb">A dupla perfeita para um lanche rápido e extremamente saboroso.</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-6 rounded-lg" Outlined="true" Style="border-color: #333; background: #222; color: white; height: 100%">
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Class="mb-4 font-weight-bold">10% OFF</MudChip>
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-1">DOBRADINHA</MudText>
                    <MudText Typo="Typo.caption" Class="mb-4 d-block" Style="color: #888">SANDUÍCHE + ACOMPANHAMENTO</MudText>
                    <MudText Typo="Typo.body2" Style="color: #bbb">Todo o sabor do nosso burger com o acompanhamento mais crocante.</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudContainer>

@code {
    private List<MenuItemResponse> _menuItems = new();
    [Inject] private HttpClient HttpClient { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        try {
            _menuItems = await HttpClient.GetFromJsonAsync<List<MenuItemResponse>>("api/menu") ?? new();
        } catch { }
    }

    private string GetImageUrl(string? url) => string.IsNullOrEmpty(url) ? "https://via.placeholder.com/200" : $"{HttpClient.BaseAddress}{url.TrimStart('/')}";

    private string TranslateType(string type) => type switch
    {
        "Sandwich" => "Sanduíche",
        "Side" => "Acompanhamento",
        "Drink" => "Refrigerante",
        _ => type
    };
}
