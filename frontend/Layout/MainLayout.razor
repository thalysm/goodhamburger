@inherits LayoutComponentBase
@namespace GoodHamburger.Frontend.Layout

<MudThemeProvider Theme="_currentTheme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Surface">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Primary" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <div class="d-flex align-center mr-2 mr-md-6">
            <MudIcon Icon="@Icons.Material.Filled.RestaurantMenu" Color="Color.Primary" Class="mr-2" />
            <MudHidden Breakpoint="Breakpoint.Xs">
                <MudText Typo="Typo.h6" Color="Color.Primary" Class="line-height-1" Style="font-weight: 900; letter-spacing: 1px">GOOD HAMBURGER</MudText>
            </MudHidden>
        </div>
        
        <div class="flex-grow-1 d-flex justify-center mx-1 mx-md-4" style="max-width: 500px">
            <MudTextField T="string"
                          Value="SearchService.SearchQuery" 
                          ValueChanged="@(s => SearchService.SearchQuery = s)"
                          Placeholder="@GetSearchPlaceholder()" 
                          Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Search" 
                          Variant="Variant.Outlined" 
                          Margin="Margin.Dense"
                          Immediate="true"
                          FullWidth="true"
                          Style="background-color: #f5f5f5" />
        </div>

        <MudSpacer />
        
        <div class="d-flex align-center">
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudText Color="Color.Success" Typo="Typo.subtitle2" Class="mr-4">● LOJA ABERTA</MudText>
            </MudHidden>
            <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Primary" Size="Size.Small" />
            <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary" Size="Size.Small" />
        </div>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="1" Variant="@DrawerVariant.Responsive">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 my-md-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<style>
    .line-height-1 {
        line-height: 1;
    }
</style>

@implements IDisposable

@code {
    [Inject] private SearchService SearchService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    protected override void OnInitialized()
    {
        Nav.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e) => StateHasChanged();

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
    }

    private string GetSearchPlaceholder()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri).ToLower();
        if (string.IsNullOrEmpty(relativePath) || relativePath == "orders")
            return "BUSCAR PEDIDO (ID)...";
        
        return "BUSCAR NO CARDÁPIO...";
    }

    private MudTheme _currentTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#FF5A1F",
            AppbarBackground = "#ffffff",
            DrawerBackground = "#ffffff",
            Surface = "#ffffff",
            Background = "#f8f9fa"
        }
    };
}
